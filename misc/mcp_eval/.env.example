# ── PARCS cluster ─────────────────────────────────────────────────────────────
# Required: URL of the PARCS MCP SSE server
MCP__CLUSTER_URL=http://34.76.43.4:8080

# ── LLM provider ──────────────────────────────────────────────────────────────
# Set provider to "vertexai" to use Google Vertex AI (recommended for eval)
LLM__PROVIDER=vertexai
LLM__PROJECT=parcs-gcp          # your GCP project ID
LLM__LOCATION=us-central1
LLM__TEMPERATURE=0.0            # 0 = deterministic, better for benchmarking

# Models to evaluate (comma-separated) — used by run_eval.py
EVAL__MODELS=gemini-2.5-flash,gemini-2.5-pro

# Alternatively, use an OpenAI-compatible local endpoint:
# LLM__PROVIDER=openai
# LLM__MODEL_NAME=qwen/qwen3.6-27b
# LLM__BASE_URL=http://localhost:1234/v1
# LLM__API_KEY=lmstudio

# ── Evaluation settings ────────────────────────────────────────────────────────
# Where results are written (CSV, appended incrementally)
EVAL__RESULTS_FILE=results/benchmark_results.csv
# Timeout per agent run in seconds (15 min default; longest tasks need ~10 min)
EVAL__TIMEOUT_SECONDS=900
# Restrict to specific tasks (blank = all 15)
# EVAL__TASK_IDS=1,2,3

# ── LangSmith tracing (optional but recommended) ──────────────────────────────
LANGSMITH__TRACING_V2=true
LANGSMITH__ENDPOINT=https://api.smith.langchain.com
LANGSMITH__PROJECT=parcs-agent-benchmark
LANGSMITH__API_KEY=

# ── HuggingFace token (for private datasets) ──────────────────────────────────
HF_TOKEN=
