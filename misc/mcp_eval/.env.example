# PARCS MCP server (required)
MCP__CLUSTER_URL=http://localhost:5000

# LLM endpoint (defaults shown; override for non-local providers)
# LLM__MODEL_NAME=qwen/qwen3.6-27b
# LLM__TEMPERATURE=0.6
# LLM__BASE_URL=http://localhost:1234/v1
# LLM__API_KEY=lmstudio

# Skills / memory directories (default: package-relative)
# PATHS__SKILLS_DIR=
# PATHS__MEMORY_DIR=

# LangSmith tracing (optional)
LANGSMITH__TRACING_V2=true
LANGSMITH__ENDPOINT=https://api.smith.langchain.com
LANGSMITH__PROJECT=parcs-agent-benchmark
LANGSMITH__API_KEY=

# Hugging Face token, used by `datasets` (optional)
HF_TOKEN=
